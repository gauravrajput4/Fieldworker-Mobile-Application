<header class="topbar">
  <div class="topbar-left">
    <button
      type="button"
      class="mobile-nav-toggle"
      id="mobileNavToggle"
      aria-label="Toggle navigation"
      aria-controls="sidebar"
      aria-expanded="false"
    >
      <span class="material-symbols-outlined">menu</span>
    </button>

    <div class="topbar-brand"><%= title %></div>

    <label class="topbar-search">
      <span class="material-symbols-outlined">search</span>
      <input
        type="text"
        id="pageSearch"
        placeholder="<%= searchPlaceholder || 'Search dashboard data...' %>"
      >
    </label>
  </div>

  <div class="topbar-right">
    <button type="button" class="icon-button">
      <span class="material-symbols-outlined">notifications</span>
      <span class="notification-dot"></span>
    </button>
    <button type="button" class="icon-button">
      <span class="material-symbols-outlined">help_outline</span>
    </button>
    <div class="topbar-divider"></div>
    <div class="profile-chip">
      <div class="profile-copy">
        <span class="profile-label">Admin Profile</span>
        <span class="profile-name"><%= user?.name || 'Administrator' %></span>
      </div>
      <div class="profile-avatar">
        <img src="/images/app-icon.png" alt="Admin avatar">
      </div>
    </div>
  </div>
</header>
