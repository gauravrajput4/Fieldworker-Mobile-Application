<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Farmers' }) %>
<body data-page="farmers">
  <% const farmerList = Array.isArray(farmers) ? farmers : []; %>
  <% const fieldworkerList = Array.isArray(fieldworkers) ? fieldworkers : []; %>
  <div class="overlay" id="overlay"></div>

  <div class="admin-layout">
    <%- include('partials/sidebar', { activePage }) %>

    <div class="shell">
      <%- include('partials/header', {
        user,
        title: 'Farmers Management',
        searchPlaceholder: 'Search farmers, villages, mobile, or fieldworkers...'
      }) %>

      <main class="page">
        <section class="page-hero">
          <div class="page-hero-copy">
            <span class="eyebrow">Registry Oversight</span>
            <h1 class="page-title">Farmer Management</h1>
            <p class="page-description">
              Review farmer profiles, village coverage, fieldworker assignment, login linkage, and sync readiness from one responsive workspace.
            </p>
          </div>
          <div class="hero-actions">
            <span class="filter-chip"><%= farmerList.filter((item) => item.syncStatus !== 'SYNCED').length %> pending sync</span>
            <button type="button" class="button primary" data-open-modal="farmerFormModal" data-mode="create">
              <span class="material-symbols-outlined">person_add</span>
              <span>Add Farmer</span>
            </button>
          </div>
        </section>

        <section class="stats-grid">
          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">person_pin</span></div>
              <span class="metric-pill">Live registry</span>
            </div>
            <p class="metric-label">Total Farmers</p>
            <p class="metric-value"><%= farmerList.length %></p>
            <div class="metric-subtext">Active farmer records available to the admin team</div>
          </article>
          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">badge</span></div>
              <span class="metric-pill">Coverage</span>
            </div>
            <p class="metric-label">Assigned Fieldworkers</p>
            <p class="metric-value"><%= farmerList.filter((item) => item.createdBy?._id).length %></p>
            <div class="metric-subtext"><%= farmerList.filter((item) => !item.createdBy?._id).length %> records are not assigned</div>
          </article>
          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">verified_user</span></div>
              <span class="metric-pill">Access</span>
            </div>
            <p class="metric-label">Login Enabled</p>
            <p class="metric-value"><%= farmerList.filter((item) => item.userId?._id || item.userId).length %></p>
            <div class="metric-subtext"><%= farmerList.filter((item) => !(item.userId?._id || item.userId)).length %> profiles are not linked to an account</div>
          </article>
          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">sync_problem</span></div>
              <span class="metric-pill">Action needed</span>
            </div>
            <p class="metric-label">Pending Sync Records</p>
            <p class="metric-value"><%= farmerList.filter((item) => item.syncStatus !== 'SYNCED').length %></p>
            <div class="metric-subtext">These farmer profiles still need to sync to the server</div>
          </article>
        </section>

        <section class="toolbar">
          <div class="toolbar-actions">
            <span class="filter-chip">
              <span class="material-symbols-outlined">groups</span>
              <span><%= fieldworkerList.length %> fieldworkers</span>
            </span>
            <span class="filter-chip">
              <span class="material-symbols-outlined">home_pin</span>
              <span><%= new Set(farmerList.map((item) => item.village).filter(Boolean)).size %> villages</span>
            </span>
          </div>
          <div class="toolbar-actions">
            <span class="meta-text">Showing <%= farmerList.length %> farmers</span>
          </div>
        </section>

        <section class="table-shell">
          <div class="table-scroll">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Farmer Name</th>
                  <th>Farmer ID</th>
                  <th>Village</th>
                  <th>Assigned Fieldworker</th>
                  <th>Mobile Number</th>
                  <th>Login Status</th>
                  <th>Sync Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% farmerList.forEach((farmer) => { %>
                  <% const farmerId = farmer._id || farmer.id || ''; %>
                  <tr
                    data-search-row="<%= `${farmer.name} ${farmer.village} ${farmer.mobile} ${farmer.createdBy?.name || 'Not Assigned'} ${farmer.address || ''}` %>"
                    data-row-id="<%= farmerId %>"
                  >
                    <td>
                      <div class="identity-cell">
                        <div class="avatar"><%= (farmer.name || 'F').charAt(0).toUpperCase() %></div>
                        <div class="identity-meta">
                          <strong><%= farmer.name %></strong>
                          <span><%= farmer.address || 'Address not available' %></span>
                        </div>
                      </div>
                    </td>
                    <td><span class="mono"><%= farmerId || 'N/A' %></span></td>
                    <td><strong><%= farmer.village || 'N/A' %></strong></td>
                    <td><%= farmer.createdBy?.name || 'Not Assigned' %></td>
                    <td><%= farmer.mobile || 'N/A' %></td>
                    <td>
                      <span class="badge <%= farmer.userId ? 'success' : 'error' %>">
                        <%= farmer.userId ? 'Enabled' : 'Not Linked' %>
                      </span>
                    </td>
                    <td>
                      <span class="badge <%= farmer.syncStatus === 'SYNCED' ? 'success' : 'pending' %>"><%= farmer.syncStatus || 'PENDING' %></span>
                    </td>
                    <td>
                      <div class="action-row">
                        <button type="button" class="action-button" title="View" data-action="view-farmer" data-id="<%= farmerId %>">
                          <span class="material-symbols-outlined">visibility</span>
                        </button>
                        <button type="button" class="action-button" title="Edit" data-action="edit-farmer" data-id="<%= farmerId %>">
                          <span class="material-symbols-outlined">edit</span>
                        </button>
                        <button
                          type="button"
                          class="action-button danger"
                          title="Delete"
                          data-action="delete-record"
                          data-id="<%= farmerId %>"
                          data-record-type="farmer"
                          data-record-label="<%= farmer.name %>"
                          data-delete-url="/farmers/<%= farmerId %>"
                        >
                          <span class="material-symbols-outlined">delete</span>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
                <% if (farmerList.length === 0) { %>
                  <tr><td colspan="8" class="empty-state">No farmers registered yet</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </div>

  <div class="modal-shell" id="farmerViewModal" aria-hidden="true">
    <div class="modal-card detail-modal">
      <div class="modal-head">
        <div>
          <span class="eyebrow">Farmer Profile</span>
          <h3>Farmer Details</h3>
        </div>
        <button type="button" class="icon-button" data-close-modal><span class="material-symbols-outlined">close</span></button>
      </div>
      <div class="detail-grid" id="farmerDetailGrid"></div>
    </div>
  </div>

  <div class="modal-shell" id="farmerFormModal" aria-hidden="true">
    <div class="modal-card form-modal">
      <div class="modal-head">
        <div>
          <span class="eyebrow" id="farmerFormEyebrow">Registry Update</span>
          <h3 id="farmerFormTitle">Add Farmer</h3>
        </div>
        <button type="button" class="icon-button" data-close-modal><span class="material-symbols-outlined">close</span></button>
      </div>
      <form class="form-stack" id="farmerForm" data-resource="farmer">
        <input type="hidden" name="id" id="farmerId">
        <div class="form-grid two-col">
          <div>
            <label class="field-label" for="farmerName">Farmer Name</label>
            <input class="field-control" id="farmerName" name="name" required>
          </div>
          <div>
            <label class="field-label" for="farmerVillage">Village</label>
            <input class="field-control" id="farmerVillage" name="village" required>
          </div>
          <div>
            <label class="field-label" for="farmerMobile">Mobile Number</label>
            <input class="field-control" id="farmerMobile" name="mobile" required>
          </div>
          <div>
            <label class="field-label" for="farmerAssignment">Assigned Fieldworker</label>
            <select class="field-control" id="farmerAssignment" name="createdBy">
              <option value="">Not Assigned</option>
              <% fieldworkerList.forEach((fieldworker) => { %>
                <option value="<%= fieldworker._id || fieldworker.id %>"><%= fieldworker.name %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="field-label" for="farmerSyncStatus">Sync Status</label>
            <select class="field-control" id="farmerSyncStatus" name="syncStatus">
              <option value="SYNCED">SYNCED</option>
              <option value="PENDING">PENDING</option>
            </select>
          </div>
          <div>
            <label class="field-label inline-toggle">
              <input type="checkbox" id="farmerCreateLogin" name="createLoginAccount" value="true">
              <span>Create farmer login account</span>
            </label>
          </div>
        </div>
        <div id="farmerLoginPasswordWrap" hidden>
          <label class="field-label" for="farmerPassword">Account Password</label>
          <input class="field-control" id="farmerPassword" name="accountPassword" type="password">
        </div>
        <div>
          <label class="field-label" for="farmerAddress">Address</label>
          <textarea class="field-control textarea" id="farmerAddress" name="address"></textarea>
        </div>
        <div class="modal-actions">
          <button type="button" class="button secondary" data-close-modal>Cancel</button>
          <button type="submit" class="button primary" data-submit-label="Save Farmer">
            <span class="button-text">Save Farmer</span>
            <span class="button-loader" aria-hidden="true"></span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-shell" id="confirmDeleteModal" aria-hidden="true">
    <div class="modal-card confirm-modal">
      <div class="modal-head">
        <div>
          <span class="eyebrow">Safe Action</span>
          <h3>Confirm Deletion</h3>
        </div>
        <button type="button" class="icon-button" data-close-modal><span class="material-symbols-outlined">close</span></button>
      </div>
      <p class="page-description" id="deleteModalMessage">Are you sure you want to delete this farmer?</p>
      <div class="modal-actions">
        <button type="button" class="button secondary" data-close-modal>Cancel</button>
        <button type="button" class="button danger" id="confirmDeleteButton">
          <span class="button-text">Delete</span>
          <span class="button-loader" aria-hidden="true"></span>
        </button>
      </div>
    </div>
  </div>

  <div class="toast-stack" id="toastStack"></div>

  <script id="farmersData" type="application/json"><%- JSON.stringify({ farmers: farmerList, fieldworkers: fieldworkerList }).replace(/</g, '\\u003c') %></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
