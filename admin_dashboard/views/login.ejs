<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Login' }) %>
<body>
  <main class="login-screen">
    <section class="login-card">
      <div class="login-brand">
        <img src="/images/app-icon.png" alt="Digital Steward">
        <h1>Digital Steward</h1>
        <p>Administrative control for the field management platform.</p>
      </div>

      <% if (error) { %>
        <div class="notice error"><%= error %></div>
      <% } %>

      <form method="POST" action="/login" class="form-stack">
        <div>
          <label class="field-label" for="email">Email Address</label>
          <input class="field-control" type="email" id="email" name="email" required placeholder="admin@example.com">
        </div>
        <div>
          <label class="field-label" for="password">Secure Password</label>
          <input class="field-control" type="password" id="password" name="password" required placeholder="Enter your password">
        </div>
        <button type="submit" class="button primary" style="width: 100%;">
          <span class="material-symbols-outlined">login</span>
          <span>Enter Dashboard</span>
        </button>
      </form>

      <div class="notice info" style="margin-top: 18px;">
        Admin account required. Sign in with a backend user whose role is set to <strong>admin</strong>.
      </div>
    </section>
  </main>
</body>
</html>
