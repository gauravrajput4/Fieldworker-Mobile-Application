<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Fieldworkers' }) %>
<body data-page="users">
  <% const userList = Array.isArray(users) ? users : []; %>
  <div class="overlay" id="overlay"></div>

  <div class="admin-layout">
    <%- include('partials/sidebar', { activePage }) %>

    <div class="shell">
      <%- include('partials/header', {
        user,
        title: 'Fieldworker Management',
        searchPlaceholder: 'Search fieldworkers by name, role, email, or mobile...'
      }) %>

      <main class="page">
        <section class="page-hero">
          <div class="page-hero-copy">
            <span class="eyebrow">Workforce Control</span>
            <h1 class="page-title">Fieldworker Management</h1>
            <p class="page-description">
              Add, update, and remove fieldworkers with a clean operational workflow that keeps access control safe and traceable.
            </p>
          </div>
          <div class="hero-actions">
            <span class="filter-chip"><%= userList.length %> team members</span>
            <button type="button" class="button primary" data-open-modal="fieldworkerFormModal" data-mode="create">
              <span class="material-symbols-outlined">person_add</span>
              <span>Add Fieldworker</span>
            </button>
          </div>
        </section>

        <section class="stats-grid">
          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">group</span></div>
              <span class="metric-pill">Admin view</span>
            </div>
            <p class="metric-label">Total Team Members</p>
            <p class="metric-value"><%= userList.length %></p>
            <div class="metric-subtext">Active fieldworker accounts available for assignment</div>
          </article>
          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">badge</span></div>
              <span class="metric-pill">Primary role</span>
            </div>
            <p class="metric-label">With Mobile</p>
            <p class="metric-value"><%= userList.filter((item) => item.mobile).length %></p>
            <div class="metric-subtext"><%= userList.filter((item) => !item.mobile).length %> fieldworkers need contact numbers</div>
          </article>
          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">mail</span></div>
              <span class="metric-pill">Directory</span>
            </div>
            <p class="metric-label">Email Linked</p>
            <p class="metric-value"><%= userList.filter((item) => item.email).length %></p>
            <div class="metric-subtext"><%= userList.filter((item) => !item.email).length %> users still rely on mobile only</div>
          </article>
          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">calendar_month</span></div>
              <span class="metric-pill">Recent hires</span>
            </div>
            <p class="metric-label">Added This Month</p>
            <p class="metric-value"><%= userList.filter((item) => new Date(item.createdAt).getMonth() === new Date().getMonth() && new Date(item.createdAt).getFullYear() === new Date().getFullYear()).length %></p>
            <div class="metric-subtext">New fieldworker accounts created in the current month</div>
          </article>
        </section>

        <section class="table-shell">
          <div class="table-scroll">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Role</th>
                  <th>Email</th>
                  <th>Mobile</th>
                  <th>Created Date</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% userList.forEach((userItem) => { %>
                  <% const userId = userItem._id || userItem.id || ''; %>
                  <tr data-search-row="<%= `${userItem.name} ${userItem.role} ${userItem.email || ''} ${userItem.mobile || ''}` %>" data-row-id="<%= userId %>">
                    <td>
                      <div class="identity-cell">
                        <div class="avatar"><%= (userItem.name || 'U').charAt(0).toUpperCase() %></div>
                        <div class="identity-meta">
                          <strong><%= userItem.name %></strong>
                          <span>ID: <%= userId || 'N/A' %></span>
                        </div>
                      </div>
                    </td>
                    <td><span class="badge success"><%= userItem.role %></span></td>
                    <td><%= userItem.email || 'N/A' %></td>
                    <td><%= userItem.mobile || 'N/A' %></td>
                    <td><%= userItem.createdAt ? new Date(userItem.createdAt).toLocaleDateString() : 'N/A' %></td>
                    <td>
                      <div class="action-row">
                        <button type="button" class="action-button" title="Edit" data-action="edit-user" data-id="<%= userId %>">
                          <span class="material-symbols-outlined">edit</span>
                        </button>
                        <button
                          type="button"
                          class="action-button danger"
                          title="Delete"
                          data-action="delete-record"
                          data-id="<%= userId %>"
                          data-record-type="fieldworker"
                          data-record-label="<%= userItem.name %>"
                          data-delete-url="/users/<%= userId %>"
                        >
                          <span class="material-symbols-outlined">delete</span>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
                <% if (userList.length === 0) { %>
                  <tr><td colspan="6" class="empty-state">No fieldworkers found</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </div>

  <div class="modal-shell" id="fieldworkerFormModal" aria-hidden="true">
    <div class="modal-card form-modal">
      <div class="modal-head">
        <div>
          <span class="eyebrow" id="userFormEyebrow">Workforce Control</span>
          <h3 id="userFormTitle">Add Fieldworker</h3>
        </div>
        <button type="button" class="icon-button" data-close-modal><span class="material-symbols-outlined">close</span></button>
      </div>
      <form class="form-stack" id="fieldworkerForm" data-resource="user">
        <input type="hidden" name="id" id="userId">
        <div class="form-grid two-col">
          <div>
            <label class="field-label" for="userName">Name</label>
            <input class="field-control" id="userName" name="name" required>
          </div>
          <input type="hidden" id="userRole" name="role" value="fieldworker">
          <div>
            <label class="field-label" for="userEmail">Email</label>
            <input class="field-control" id="userEmail" name="email" type="email">
          </div>
          <div>
            <label class="field-label" for="userMobile">Mobile</label>
            <input class="field-control" id="userMobile" name="mobile">
          </div>
        </div>
        <div>
          <label class="field-label" for="userPassword">Password</label>
          <input class="field-control" id="userPassword" name="password" type="password">
          <span class="meta-text">Required when creating a fieldworker. Leave blank during edit to keep the existing password.</span>
        </div>
        <div class="modal-actions">
          <button type="button" class="button secondary" data-close-modal>Cancel</button>
          <button type="submit" class="button primary" data-submit-label="Save Fieldworker">
            <span class="button-text">Save Fieldworker</span>
            <span class="button-loader" aria-hidden="true"></span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-shell" id="confirmDeleteModal" aria-hidden="true">
    <div class="modal-card confirm-modal">
      <div class="modal-head">
        <div>
          <span class="eyebrow">Safe Action</span>
          <h3>Confirm Deletion</h3>
        </div>
        <button type="button" class="icon-button" data-close-modal><span class="material-symbols-outlined">close</span></button>
      </div>
      <p class="page-description" id="deleteModalMessage">Are you sure you want to delete this fieldworker?</p>
      <div class="modal-actions">
        <button type="button" class="button secondary" data-close-modal>Cancel</button>
        <button type="button" class="button danger" id="confirmDeleteButton">
          <span class="button-text">Delete</span>
          <span class="button-loader" aria-hidden="true"></span>
        </button>
      </div>
    </div>
  </div>

  <div class="toast-stack" id="toastStack"></div>

  <script id="usersData" type="application/json"><%- JSON.stringify({ users: userList }).replace(/</g, '\\u003c') %></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
