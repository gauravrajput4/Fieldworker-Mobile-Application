<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Dashboard' }) %>
<body data-page="dashboard">
  <div class="overlay" id="overlay"></div>

  <div class="admin-layout">
    <%- include('partials/sidebar', { activePage }) %>

    <div class="shell">
      <%- include('partials/header', {
        user,
        title: 'Operational Overview',
        searchPlaceholder: 'Search field data...'
      }) %>

      <main class="page">
        <section class="page-hero">
          <div class="page-hero-copy">
            <span class="eyebrow">Administrative Control</span>
            <h1 class="page-title">Fieldworker Management System</h1>
            <p class="page-description">
              Monitor farmer coverage, active fieldworkers, sync queues, and system operations from one clean control center.
            </p>
          </div>
          <div class="hero-actions">
            <a href="/users" class="button secondary">Manage Fieldworkers</a>
            <a href="/sync-logs" class="button primary">
              <span class="material-symbols-outlined">sync</span>
              <span>Review Sync Queue</span>
            </a>
          </div>
        </section>

        <section class="stats-grid">
          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">person_pin</span></div>
              <span class="metric-pill">Live total</span>
            </div>
            <p class="metric-label">Total Farmers</p>
            <p class="metric-value"><%= stats.totalFarmers %></p>
            <div class="metric-subtext"><%= stats.syncedFarmers %> synced, <%= stats.pendingFarmers %> pending</div>
          </article>

          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">badge</span></div>
              <span class="metric-pill"><%= stats.totalUsers %> total users</span>
            </div>
            <p class="metric-label">Total Fieldworkers</p>
            <p class="metric-value"><%= stats.totalFieldworkers %></p>
            <div class="metric-subtext">Staff actively managing field registrations and support</div>
          </article>

          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">sync</span></div>
              <span class="metric-pill"><%= stats.pendingSyncRecords %> records</span>
            </div>
            <p class="metric-label">Pending Syncs</p>
            <p class="metric-value"><%= stats.pendingSyncRecords %></p>
            <div class="metric-subtext">Farmer and crop records still awaiting server confirmation</div>
          </article>

          <article class="metric-card">
            <div class="metric-card-head">
              <div class="metric-icon"><span class="material-symbols-outlined">forum</span></div>
              <span class="metric-pill"><%= stats.openQueries %> open</span>
            </div>
            <p class="metric-label">Support Queries</p>
            <p class="metric-value"><%= stats.totalQueries %></p>
            <div class="metric-subtext"><%= stats.resolvedQueries %> resolved across the current support queue</div>
          </article>
        </section>

        <section class="overview-grid">
          <article class="section-card">
            <div class="section-head">
              <div>
                <h2>Platform Activity</h2>
                <div class="meta-text">System-wide comparison of registrations, staffing, crops, and support tickets</div>
              </div>
              <div class="chart-pill-group">
                <span class="chip">Monthly</span>
                <span class="chip" style="background: var(--primary-deep); color: #fff;">Quarterly</span>
              </div>
            </div>
            <div class="chart-shell">
              <canvas id="dashboardChart"></canvas>
            </div>
          </article>

          <article class="gradient-card">
            <h3 style="margin: 0; font-family: 'Lexend', sans-serif; font-size: 1.4rem;">Operations Snapshot</h3>
            <p class="muted-on-dark">A fast read on account coverage and outstanding operational work.</p>
            <div class="insight-list" style="margin-top: 28px;">
              <div>
                <div class="activity-item" style="background: rgba(255,255,255,0.08); color: #fff;">
                  <strong>Farmer Login Accounts</strong>
                  <span style="color: rgba(255,255,255,0.8);"><%= stats.totalFarmerAccounts %></span>
                </div>
              </div>
              <div>
                <div class="activity-item" style="background: rgba(255,255,255,0.08); color: #fff;">
                  <strong>Pending Farmer Syncs</strong>
                  <span style="color: rgba(255,255,255,0.8);"><%= stats.pendingFarmers %></span>
                </div>
              </div>
              <div>
                <div class="activity-item" style="background: rgba(255,255,255,0.08); color: #fff;">
                  <strong>Open Support Queries</strong>
                  <span style="color: rgba(255,255,255,0.8);"><%= stats.openQueries %></span>
                </div>
              </div>
            </div>
          </article>
        </section>

        <section class="content-grid">
          <article class="section-card tonal">
            <div class="section-head">
              <h3>Recent Farmer Registrations</h3>
              <a class="section-link" href="/farmers">View all farmers</a>
            </div>
            <div class="activity-list">
              <% recentFarmers.forEach((farmer) => { %>
                <div class="activity-item" data-search-row="<%= `${farmer.name} ${farmer.village} ${farmer.mobile}` %>">
                  <div>
                    <strong><%= farmer.name %></strong>
                    <span><%= farmer.village %> • <%= farmer.mobile %></span>
                  </div>
                  <span class="badge <%= farmer.syncStatus === 'SYNCED' ? 'success' : 'pending' %>"><%= farmer.syncStatus %></span>
                </div>
              <% }) %>
              <% if (recentFarmers.length === 0) { %>
                <div class="empty-state">No farmers available</div>
              <% } %>
            </div>
          </article>

          <article class="section-card">
            <div class="section-head">
              <h3>Recent Field Activity</h3>
              <a class="section-link" href="/queries">View all queries</a>
            </div>
            <div class="activity-list">
              <% recentQueries.forEach((query) => { %>
                <div class="activity-item" data-search-row="<%= `${query.farmerId?.name || ''} ${query.cropId?.cropName || ''} ${query.description || ''}` %>">
                  <div>
                    <strong><%= query.farmerId?.name || 'N/A' %></strong>
                    <span><%= query.cropId?.cropName || 'N/A' %> • <%= query.fieldworkerId?.name || 'Unassigned' %></span>
                  </div>
                  <span class="badge <%= query.status === 'RESOLVED' ? 'success' : 'pending' %>"><%= query.status %></span>
                </div>
              <% }) %>
              <% if (recentQueries.length === 0) { %>
                <div class="empty-state">No farmer queries yet</div>
              <% } %>
            </div>
          </article>
        </section>

        <section class="table-shell">
          <div class="section-head" style="padding: 24px 24px 0;">
            <div>
              <h3>Field Worker Coverage</h3>
              <div class="meta-text">Top active workers by farmer coverage and support load</div>
            </div>
            <a class="section-link" href="/users">View all users</a>
          </div>
          <div class="table-scroll">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Field Worker</th>
                  <th>Contact</th>
                  <th>Farmers Managed</th>
                  <th>Open Queries</th>
                  <th>Created</th>
                </tr>
              </thead>
              <tbody>
                <% topFieldworkers.forEach((fieldworker) => { %>
                  <tr data-search-row="<%= `${fieldworker.name} ${fieldworker.email || ''} ${fieldworker.mobile || ''}` %>">
                    <td>
                      <div class="identity-cell">
                        <div class="avatar"><%= (fieldworker.name || 'U').charAt(0).toUpperCase() %></div>
                        <div class="identity-meta">
                          <strong><%= fieldworker.name %></strong>
                          <span><%= fieldworker.role %></span>
                        </div>
                      </div>
                    </td>
                    <td><%= fieldworker.email || fieldworker.mobile || 'N/A' %></td>
                    <td><%= fieldworker.farmersManaged %></td>
                    <td><%= fieldworker.openQueries %></td>
                    <td><%= new Date(fieldworker.createdAt).toLocaleDateString() %></td>
                  </tr>
                <% }) %>
                <% if (topFieldworkers.length === 0) { %>
                  <tr><td colspan="5" class="empty-state">No field workers found</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </section>
      </main>
    </div>
  </div>

  <script>
    window.STATS = {
      totalUsers: <%= stats.totalUsers %>,
      totalFieldworkers: <%= stats.totalFieldworkers %>,
      totalFarmers: <%= stats.totalFarmers %>,
      totalCrops: <%= stats.totalCrops %>,
      openQueries: <%= stats.openQueries %>,
      resolvedQueries: <%= stats.resolvedQueries %>
    };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
